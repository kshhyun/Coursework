setwd("~/Study/CourseWork/Coursework/BigData")
# 사용자 정의 함수 호출
setwd("~/Study/CourseWork/Coursework/BigData")        #작업 디렉토리 설정
source("user_function.R") #외부 함수 파일 로드
library(ggplot2)
library(rworldmap)
# rworldmap 패키지 지도 데이터 가져오기
data(countriesCoarse)
# 지도 공간 데이터에서 속성 데이터(텍스트 정보) 추출
info_1 = countriesCoarse@data
head(info_1, 2)
# 패키지 내장 예시 데이터 확인
info_2 = countryExData
dim(info_2)
# ggplot에서 사용할 수 있도록 지도 데이터를 데이터프레임으로 변환
df_map = fortify(countriesCoarse)
head(df_map)
# --------------------------
# 1. 전 세계 지도 시각화
ggplot(data = df_map,
aes(x = long, y = lat, group = group, fill = id)) +
geom_polygon(color = "#FFFFFF", linewidth = 0.1) +
theme_minimal() +
theme(
legend.position = "none",
panel.background = element_rect(fill = "#F4F7F9", color = NA),
panel.grid = element_blank(),
axis.text = element_blank(),  # 축 눈금 제거
axis.title = element_blank()
)
# --------------------------
# 3. 아시아 지도 시각화 (대륙별)
# 아시아 국가 추출
vec_conti = unique(info_1[info_1$REGION == "Asia", "NAME"])
# 아시아 국가만 필터링
df_asia = df_map[df_map$id %in% vec_conti, ]
# 아시아 국가별 지도 시각화
ggplot(data = df_asia,
aes(x = long, y = lat, group = group, fill = id)) +
geom_polygon(color = "#FFFFFF", linewidth = 0.2) +
# RColorBrewer 패키지 : 파스텔 색상 스펙트럼 생성
scale_fill_manual(values = colorRampPalette(RColorBrewer::brewer.pal(8, "Pastel2"))(length(vec_conti))) +
theme_minimal() +
theme(
legend.position = "none",
panel.background = element_rect(fill = "#FAFAFA", color = NA),
panel.grid = element_blank(),
axis.text = element_blank(),
axis.title = element_blank()
)
