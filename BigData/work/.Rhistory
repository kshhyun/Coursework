sum <- 0
for(i in 1:100){     # i가 1부터 100까지 1씩 증가 -> 반복
if(i %% 2 == 0) next # i를 2로 나눈 나머지가 0 -> 짝수라면 아래 과정 생략
sum <- sum + i
}
cat("1부터 100까지 홀수의 합 = ", sum, "\n")  # 2500
