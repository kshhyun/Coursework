# matrix - cbind(), rbind()
y <- matrix(1:20, nrow=4, ncol=5)
y1 <- c(11:14)
y2 <- (21:25)
cbind(y, y1) # 열벡터 추가
rbind(y, y2) # 행벡터 추가
View(y)
n1 <- cbind(y, y1) # 열벡터 추가
n2 <- rbind(y, y2) # 행벡터 추가
