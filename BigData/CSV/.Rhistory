pct <- round(pm25/sum(pm25)*100, 1)
city_labels <- paste(city, ",", pct, "%", sep="")
pie(pm25, labels=city_labels, col=greens, main="지역별 초미세먼지 농도)",
init.angle=90, clockwise=T)
