library(ggplot2)
library("rworldmap")
info_1 = countriesCoarse@data
head(info_1, 2)
info_2 = countryExData
dim(info_2)
df_map = fortify(countriesCoarse)
head(df_map)
# 1. 대륙별 지도 (전 세계 지도) 색상 수정
ggplot(data = df_map,
aes(x = long, y = lat, group = group)) +
# fill: 대륙 내부를 차분한 연회색으로 채움
# color: 국가 간 경계선을 깔끔한 흰색으로 설정
geom_polygon(fill = "#E0E0E0", color = "#FFFFFF", size = 0.2) +
# 깨끗한 지도 표현을 위해 배경을 연한 하늘색(바다)으로 설정하고 불필요한 격자 제거
theme_minimal() +
theme(
panel.background = element_rect(fill = "#EBF4FA", color = NA),
panel.grid = element_blank()
)
vec_conti = unique(info_1[info_1$REGION == "Asia", "NAME"])
# 2. 아시아 지역 지도 색상 수정
ggplot(data = df_map[df_map$id %in% vec_conti, ],
aes(x = long, y = lat, group = group)) +
# fill: 아시아 대륙을 강조하기 위해 따뜻한 올리브/베이지 톤으로 채움
# color: 경계선을 부드러운 회색으로 설정
geom_polygon(fill = "#E2D9C8", color = "#8C8C8C", size = 0.2) +
# 심플한 화이트 배경 테마 적용
theme_bw() +
labs(title = "Asia Regional Map")
# 대륙별 지도
# 국가별(id)로 색상을 다르게 지정
ggplot(data = df_map,
aes(x = long, y = lat, group = group, fill = id)) + # fill = id 추가
geom_polygon(color = "#FFFFFF", size = 0.1) + # 테두리는 흰색으로 깔끔하게
theme_minimal() +
theme(
legend.position = "none", # 국가가 너무 많아 범례는 숨깁니다
panel.background = element_rect(fill = "#F4F7F9", color = NA), # 연한 파란색 바다 배경
panel.grid = element_blank()
)
# 대륙별 지도
ggplot(data = df_map,
aes(x = long, y = lat,
group = group)) +
geom_polygon(fill = "#FFFFFF",
color = "#000000")
# 대륙별 지도
# 국가별(id)로 색상을 다르게 지정
ggplot(data = df_map,
aes(x = long, y = lat, group = group, fill = id)) + # fill = id 추가
geom_polygon(color = "#FFFFFF", size = 0.1) + # 테두리는 흰색으로 깔끔하게
theme_minimal() +
theme(
legend.position = "none", # 국가가 너무 많아 범례는 숨깁니다
panel.background = element_rect(fill = "#F4F7F9", color = NA), # 연한 파란색 바다 배경
panel.grid = element_blank()
)
# 아시아 데이터 필터링
df_asia = df_map[df_map$id %in% vec_conti, ]
info_1 = countriesCoarse@data
vec_conti = unique(info_1[info_1$REGION == "Asia", "NAME"])
# 아시아 데이터 필터링
df_asia = df_map[df_map$id %in% vec_conti, ]
# 아시아 국가별(id)로 색상을 다르게 지정
ggplot(data = df_asia,
aes(x = long, y = lat, group = group, fill = id)) + # fill = id 추가
geom_polygon(color = "#404040", size = 0.2) + # 테두리는 짙은 회색
# viridis 팔레트를 사용하여 세련되고 시인성 높은 색상 조합 적용
scale_fill_viridis_d(option = "plasma") +
theme_bw() +
theme(
legend.position = "none", # 국가명이 많으므로 범례 제외 (필요시 제거 가능)
panel.grid.major = element_blank(),
panel.grid.minor = element_blank()
) +
labs(title = "Colorful Asia Map", x = "Longitude", y = "Latitude")
info_1 = countriesCoarse@data
vec_conti = unique(info_1[info_1$REGION == "Asia", "NAME"])
df_asia = df_map[df_map$id %in% vec_conti, ]
# 파스텔 톤 아시아 국가별 지도 시각화
ggplot(data = df_asia,
aes(x = long, y = lat, group = group, fill = id)) + # 국가별 매핑
geom_polygon(color = "#FFFFFF", size = 0.2) + # 경계선을 흰색으로 하여 부드러움 극대화
# 부드러운 파스텔톤 팔레트(Pastel2) 적용
scale_fill_manual(values = colorRampPalette(RColorBrewer::brewer.pal(8, "Pastel2"))(length(vec_conti))) +
theme_minimal() +
theme(
legend.position = "none", # 국가가 많아 범례는 숨김
panel.background = element_rect(fill = "#FAFAFA", color = NA), # 매우 연한 크림빛 배경
panel.grid = element_blank(),
axis.text = element_blank(),
axis.title = element_blank()
) +
labs(title = "Pastel Tone Asia Map")
library(ggplot2)
library("rworldmap")
# 1. 데이터 준비 및 대륙(REGION) 정보 매핑
df_map = fortify(countriesCoarse)
info_1 = countriesCoarse@data[, c("NAME", "REGION")]
# 지도 데이터(id)와 국가 정보(NAME)를 결합하여 대륙 정보 추가
df_map_region = merge(df_map, info_1, by.x = "id", by.y = "NAME", all.x = TRUE)
# 2. 파스텔 톤 전 세계 지도 시각화
ggplot(data = df_map_region,
aes(x = long, y = lat, group = group, fill = REGION)) + # 대륙별로 색상 매핑
geom_polygon(color = "#FFFFFF", size = 0.15) + # 테두리는 깔끔한 흰색
# RColorBrewer의 파스텔 팔레트(Pastel1) 적용
scale_fill_brewer(palette = "Pastel1", na.value = "#E0E0E0") +
theme_minimal() +
theme(
legend.title = element_blank(),
legend.position = "bottom", # 범례를 하단으로 이동
panel.background = element_rect(fill = "#F0F5F9", color = NA), # 연한 파스텔 바다색
panel.grid = element_blank(),
axis.text = element_blank(), # 지도를 더 넓게 보기 위해 축 눈금 제거
axis.title = element_blank()
)
