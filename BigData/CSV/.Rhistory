# if-else-if [다중 if]
s <- 98
if(s>=95){
g <- "A+"
} else if (s>=90) {
g <- "A0"
} else if (s>=85) {
g <- "B+"
} else if (s>=80) {
g <- "B0"
} else if (s>=75) {
g <- "C+"
} else if (s>=70) {
g <- "C0"
} else if (s>=65) {
g <- "D+"
} else if (s>=60) {
g <- "D0"
} else {
g <- "F"
}
print(g)
