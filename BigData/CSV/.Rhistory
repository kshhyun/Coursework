library(survival)
library(survminer)
# 1. 데이터 로드 및 모델 적합
data(lung)
fit <- survfit(Surv(time, status) ~ sex, data = lung)
# 2. 시각화 실행
ggsurvplot(fit,
data = lung,
pval = TRUE,
risk.table = TRUE,
title = "성별에 따른 폐암 환자의 생존 곡선",
xlab = "시간 (일)",
ylab = "생존 확률",
legend.labs = c("남성", "여성"))
fit <- survfit(Surv(time, status) ~ sex, data = lung)
# 2. 시각화 실행
ggsurvplot(fit,
data = lung,
pval = TRUE,
risk.table = TRUE,
title = "성별에 따른 폐암 환자의 생존 곡선",
xlab = "시간 (일)",
ylab = "생존 확률",
legend.labs = c("남성", "여성"))
# 2. 시각화 실행
ggsplot(fit,
data = lung,
pval = TRUE,
risk.table = TRUE,
title = "성별에 따른 폐암 환자의 생존 곡선",
xlab = "시간 (일)",
ylab = "생존 확률",
legend.labs = c("남성", "여성"))
# 2. 시각화 실행
ggplot(fit,
data = lung,
pval = TRUE,
risk.table = TRUE,
title = "성별에 따른 폐암 환자의 생존 곡선",
xlab = "시간 (일)",
ylab = "생존 확률",
legend.labs = c("남성", "여성"))
