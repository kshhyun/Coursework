<?xml version="1.0" encoding="UTF-8"?>
<beans xmlns="http://www.springframework.org/schema/beans"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
     xmlns:context="http://www.springframework.org/schema/context" 
    xmlns:aop="http://www.springframework.org/schema/aop" 
    xsi:schemaLocation="
        http://www.springframework.org/schema/beans 
        http://www.springframework.org/schema/beans/spring-beans.xsd
        http://www.springframework.org/schema/aop 
        http://www.springframework.org/schema/aop/spring-aop.xsd
        http://www.springframework.org/schema/context
        http://www.springframework.org/schema/context/spring-context.xsd"> <!-- bean definitions here -->
    
    <context:component-scan base-package="com.mavenproj.movie"></context:component-scan>

    <!-- MovieDao -->
    <bean id="movieDao" class="com.mavenproj.movie.MovieDao"></bean>

    <!-- movieInfo1 + movieInfo2 -->
    <bean id="movieInfo1" class="com.mavenproj.movie.MovieDo">
        <property name="movieNum" value="1"></property>
        <property name="movieName" value="군체"></property>
        <property name="director" value="연상호"></property>
        <property name="grade" value="15"></property>
    </bean>

    <bean id="movieInfo2" class="com.mavenproj.movie.MovieDo">
        <property name="movieNum" value="2"></property>
        <property name="movieName" value="아바타"></property>
        <property name="director" value="제임스 카메론"></property>
        <property name="grade" value="12"></property>
    </bean>

    <!-- AOP -->
    <bean id="ageCheckAdvice" class="com.mavenproj.movie.AgeCheckAdvice"></bean>
    <bean id="movieInfoAdvice" class="com.mavenproj.movie.MovieInfoAdvice"></bean>
    <bean id="selectedMovieAdvice" class="com.mavenproj.movie.SelectedMovieAdvice"></bean>

    <aop:config>    <!-- 포인트컷 설정 -->
        <aop:pointcut id="playMoviePointcut"
            expression="execution(* com.mavenproj.movie..playMovie(..))" />

        <aop:pointcut id="selectMoviePointcut"
            expression="execution(* com.mavenproj.movie.MovieServiceImpl.selectMovie(..))" />

        <!-- aop:after-throwing 설정 : 나이 등급 -->
        <aop:aspect ref="ageCheckAdvice">
            <aop:after-throwing method="ageCheckAdvice"
                pointcut-ref="playMoviePointcut"
                throwing="ex" />
        </aop:aspect>

        <!-- aop:around 설정 : 영화재생 메시지-->
        <aop:aspect ref="movieInfoAdvice">
            <aop:around method="movieInfoAdvice"
                pointcut-ref="playMoviePointcut" />
        </aop:aspect>

        <!-- aop:after-returning 설정 : 영화선택 -->
        <aop:aspect ref="selectedMovieAdvice">
            <aop:after-returning method="selectedMovieAdvice"
                pointcut-ref="selectMoviePointcut"
                returning="result" />
        </aop:aspect>
    </aop:config>
</beans>